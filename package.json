{
  "name": "@the7ofdiamonds/locations",
  "version": "0.0.23",
  "description": "An NPM package used to display Map, coordinates and directions.",
  "author": "@the7ofdiamonds",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./scss": {
      "sass": "./scss/index.scss",
      "default": "./scss/index.scss"
    }
  },
  "files": [
    "dist",
    "scss"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/the7ofdiamonds/locations.git"
  },
  "bugs": {
    "url": "https://github.com/the7ofdiamonds/locations/issues"
  },
  "homepage": "https://github.com/the7ofdiamonds/locations#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite build --watch",
    "tsc:dev": "tsc --watch",
    "vite": "vite -c vite.config.ts",
    "build": "vite build",
    "preview": "vite preview --port 8080",
    "update-prod": "git push git@github.com:the7ofdiamonds/locations.git",
    "update-dev": "git push ssh://git@gitlab.jclyonsenterprises.com:2424/seven-tech/packages/javascript/locations.git",
    "workflow": "bash ../workflow.sh",
    "refactor": "npm run workflow refactor",
    "test": "echo \"No test specified\" && exit 0",
    "clean": "rimraf dist node_modules"
  },
  "dependencies": {
    "@radix-ui/react-popover": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "npm-run-all": "^4.1.5",
    "sass": "^1.89.2",
    "typescript": "^5.7.3",
    "vite": "^8.1.2",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@react-google-maps/api": "^2.19.2",
    "@reduxjs/toolkit": "^1.9.5",
    "@the7ofdiamonds/types": "latest",
    "@the7ofdiamonds/ui-ux": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^8.1.1",
    "react-router-dom": "^6.14.2",
    "use-places-autocomplete": "^4.0.1"
  }
}
