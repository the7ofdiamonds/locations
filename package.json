    "build": "npm-run-all gulp:build vite:build",
    "preview": "vite preview --port 8080",
    "gulp": "gulp",
    "vite:build": "vite build",
    "gulp:build": "gulp build",
    "update-dev": "git push locations development",
    "update-prod": "git push locations",
    "refactor": "./refactor.sh && npm run update-prod",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
