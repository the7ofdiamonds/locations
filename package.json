{
  "name": "@the7ofdiamonds/locations",
  "version": "0.0.1",
  "description": "An NPM package used to display Map, coordinates and directions.",
  "main": "index.js",
  "author": "@the7ofdiamonds",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jamelclyons/locations.git"
  },
  "bugs": {
    "url": "https://github.com/jamelclyons/locations/issues"
  },
  "homepage": "https://github.com/jamelclyons/locations#readme",
  "exports": {
    ".": {
