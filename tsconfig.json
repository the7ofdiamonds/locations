{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "declarationDir": "dist/types",
    "rootDir": "src",
    /* Overwrite these to ensure local node_modules are found */
    "baseUrl": ".", 
    "paths": {
      "*": ["./node_modules/*", "../../node_modules/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}